# Copy this file to .env.local and fill in a key to enable the Phase 3 AI
# explanation layer. The app is fully functional WITHOUT a key — explain()
# returns null and the UI shows "AI explanation disabled".
#
# The key is read server-side only (in /api/analyze via lib/ai.ts) and is
# never exposed to the client. Do NOT commit your real .env.local.

ANTHROPIC_API_KEY=
